{
    "manifest_version": 3,
    "name": "Amplitude Lens",
    "version": "1.0",
    "description": "AI-powered product analytics discovery assistant",
    "permissions": ["activeTab", "scripting", "storage", "webRequest"],
    "host_permissions": ["<all_urls>"],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "web_accessible_resources": [
      {
        "resources": [
          "resources/prompts/*.prompt",
          "resources/prompts/amplitude-growth-consultant/*.prompt",
          "resources/enthec/*.json"
        ],
        "matches": ["<all_urls>"]
      }
    ],
    "background": {
      "service_worker": "background.js"
    }
  }